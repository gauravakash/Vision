# ──────────────────────────────────────────────────────────────────────────
# X Agent — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit the real .env to version control.
# ──────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────
APP_NAME=X Agent
APP_VERSION=1.0.0
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./xagent.db

# ─── Anthropic ────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1000

# ─── Telegram (optional) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Security ─────────────────────────────────────────────────────────────
# Generate COOKIE_ENCRYPT_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPT_KEY=GENERATE_AND_PASTE_32_CHAR_BASE64_KEY_HERE

# Generate SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_AND_PASTE_64_HEX_CHAR_KEY_HERE

# ─── Scheduler ────────────────────────────────────────────────────────────
SPIKE_CHECK_INTERVAL_MINUTES=15
SPIKE_THRESHOLD_PERCENT=300.0
DRAFT_AUTO_ABORT_MINUTES=30
COOKIE_EXPIRY_DAYS=60

# ─── Rate limiting ────────────────────────────────────────────────────────
MAX_DRAFTS_PER_RUN=10
MIN_SECONDS_BETWEEN_RUNS=300
